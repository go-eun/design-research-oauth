<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<style>
/* ══ Reset ════════════════════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
button { font-family: inherit; border: none; background: none; cursor: pointer; }

/* ══ Design Tokens ════════════════════════════════════════════════════ */
:root {
  --c-primary:    #7264FF;
  --c-primary-bg: #F4F3FF;
  --c-primary-dk: #3D2FCC;
  --c-header:     #1e1e1e;
  --c-text:       #1a1a1a;
  --c-text-2:     #555;
  --c-text-3:     #aaa;
  --c-border:     #ebebeb;
  --c-border-2:   #e4e4e4;
  --c-bg:         #f4f4f4;
  --c-bg-2:       #f0f0f0;
  --c-white:      #fff;
  --c-danger:     #D85A30;
  --r-card:       16px;
  --r-sm:         8px;
  --r-pill:       100px;
}

/* ══ Body & Shell ═════════════════════════════════════════════════════ */
body {
  font-family: 'Apple SD Gothic Neo', -apple-system, BlinkMacSystemFont, sans-serif;
  background: #e8e8e8;
  display: flex;
  justify-content: center;
  padding: 32px 24px;
}
#plugin {
  width: 360px; height: 500px;
  display: flex; flex-direction: column;
  background: var(--c-bg);
  border-radius: 20px; overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,.12);
}

/* ══ Header ═══════════════════════════════════════════════════════════ */
#header {
  flex-shrink: 0; height: 40px;
  background: var(--c-header);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 12px;
}
#header-left  { display: flex; align-items: center; gap: 6px; }
#header-icon  { width: 14px; height: 14px; background: #444; border-radius: 3px; }
#header-title { font-size: 12px; font-weight: 500; color: #ccc; }
#header-close { font-size: 14px; color: #555; }

/* ══ Tab Bar ══════════════════════════════════════════════════════════ */
#tab-wrap { flex-shrink: 0; background: var(--c-white); padding: 10px; border-bottom: 1px solid var(--c-border); }
#seg { display: flex; background: var(--c-bg-2); border-radius: 10px; padding: 3px; gap: 2px; }
.seg-btn {
  flex: 1; height: 34px; border-radius: var(--r-sm);
  font-size: 12px; font-weight: 500; color: var(--c-text-3);
  display: flex; align-items: center; justify-content: center;
  transition: background .15s, color .15s;
}
.seg-btn[aria-selected="true"]                        { background: var(--c-primary); color: var(--c-white); font-weight: 700; letter-spacing: .02em; }
.seg-btn[disabled]                                    { opacity: .35; cursor: not-allowed; }
.seg-btn.is-unlocked:not([aria-selected="true"])      { color: var(--c-primary); opacity: 1; cursor: pointer; font-weight: 600; }

/* ══ Common Fixed Area ════════════════════════════════════════════════ */
#common-fixed {
  flex-shrink: 0;
  background: var(--c-white); border-bottom: 1px solid var(--c-border);
  display: flex; align-items: center; justify-content: space-between;
  padding: 10px;
}
#common-all-chip {
  display: inline-flex; align-items: center;
  height: 28px; padding: 0 10px;
  border: 1.5px solid #ddd; border-radius: var(--r-pill);
  font-size: 10px; font-weight: 500; color: var(--c-text-2);
  background: var(--c-white); white-space: nowrap;
  transition: background .12s, border-color .12s, color .12s;
}
#common-all-chip[aria-pressed="true"] { background: var(--c-primary-bg); border-color: var(--c-primary); color: var(--c-primary-dk); }
#common-n-count { font-size: 10px; font-weight: 500; color: var(--c-text-3); padding: 0 4px; }
#common-n-count span { color: var(--c-primary); font-weight: 500; }

/* ══ Screens ══════════════════════════════════════════════════════════ */
.screen { display: none; flex-direction: column; flex: 1; min-height: 0; }
.screen.is-active { display: flex; }
#screen-3 { align-items: center; justify-content: center; gap: 10px; padding: 24px; }

/* ══ Shared: Scrollable List ══════════════════════════════════════════ */
.list-wrap { flex: 1; overflow-y: auto; min-height: 0; }
.list-wrap::-webkit-scrollbar { width: 3px; }
.list-wrap::-webkit-scrollbar-thumb { background: #ccc; border-radius: 2px; }

/* ══ Shared: CTA ══════════════════════════════════════════════════════ */
.cta-wrap { flex-shrink: 0; background: var(--c-white); border-top: 1px solid var(--c-border); padding: 10px; }
.cta-btn {
  width: 100%; height: 40px;
  background: var(--c-primary); color: var(--c-white);
  border-radius: 20px; font-family: inherit;
  font-size: 14px; font-weight: 700; letter-spacing: .02em;
  transition: background .2s;
}
.cta-btn:disabled  { background: var(--c-bg-2); color: var(--c-text-3); cursor: not-allowed; }
.cta-btn.is-counting { background: var(--c-danger); }

/* ══ Shared: Chip ═════════════════════════════════════════════════════ */
.chip {
  display: inline-flex; align-items: center; gap: 5px;
  height: 28px; padding: 0 9px 0 3px;
  border: 1.5px solid var(--c-border-2); border-radius: var(--r-pill);
  font-size: 9px; font-weight: 500; color: var(--c-text-2);
  background: var(--c-white); white-space: nowrap; user-select: none;
  transition: background .12s, border-color .12s, color .12s;
}
.chip.is-text-only  { padding: 0 10px; }
.chip[aria-pressed="true"] { background: var(--c-primary-bg); border-color: var(--c-primary); color: var(--c-primary-dk); }
.chip-logo {
  width: 20px; height: 20px; border-radius: 50%;
  font-size: 9px; font-weight: 700;
  display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0;
}

/* ══ Shared: Folder Card ══════════════════════════════════════════════ */
.folder { background: var(--c-white); margin: 10px 10px 0; border-radius: var(--r-card); overflow: hidden; }
.folder:last-child { margin-bottom: 10px; }
.folder-header { display: flex; align-items: center; justify-content: space-between; padding: 10px; cursor: pointer; user-select: none; }
.folder-header:active { background: #fafafa; }
.folder-header-left { display: flex; align-items: center; gap: 7px; }
.folder-arrow { font-size: 9px; color: #bbb; display: inline-block; transition: transform .2s ease; flex-shrink: 0; }
.folder-arrow.is-open { transform: rotate(90deg); }
.folder-emoji  { font-size: 15px; }
.folder-name   { font-size: 13px; font-weight: 700; letter-spacing: .02em; color: var(--c-text); }
.folder-count  { font-size: 12px; font-weight: 500; color: #bbb; margin-left: -3px; }
.folder-badge  { font-size: 9px; font-weight: 700; color: var(--c-primary); background: var(--c-primary-bg); border-radius: var(--r-pill); padding: 2px 7px; }
.folder-chips  { padding: 4px 10px 10px; display: flex; flex-wrap: wrap; gap: 6px; }

/* ══ Skeleton ═════════════════════════════════════════════════════════ */
.skeleton-card { background: var(--c-white); margin: 10px 10px 0; border-radius: var(--r-card); padding: 10px; display: flex; flex-direction: column; gap: 10px; }
.skeleton-card:last-child { margin-bottom: 10px; }
.skeleton-row  { display: flex; align-items: center; gap: 8px; }
.skeleton-chips { display: flex; gap: 6px; flex-wrap: wrap; padding-top: 2px; }
.sk { background: linear-gradient(90deg, #f0f0f0 25%, #e6e6e6 50%, #f0f0f0 75%); background-size: 200% 100%; animation: shimmer 1.3s infinite; border-radius: var(--r-sm); }
.sk-circle { border-radius: 50% !important; flex-shrink: 0; }
@keyframes shimmer { from { background-position: 200% 0; } to { background-position: -200% 0; } }

/* ══ Empty State ══════════════════════════════════════════════════════ */
.empty-state  { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; padding: 24px 16px; min-height: 100%; }
.empty-emoji  { font-size: 48px; line-height: 1; transition: opacity .3s ease; }
.empty-emoji.is-shaking { animation: shake .6s ease-in-out; }
@keyframes shake { 0%,100%{transform:rotate(0deg) scale(1);} 20%{transform:rotate(-18deg) scale(1.1);} 40%{transform:rotate(18deg) scale(1.1);} 60%{transform:rotate(-12deg) scale(1.05);} 80%{transform:rotate(12deg) scale(1.05);} }
.empty-title  { font-size: 15px; font-weight: 500; color: var(--c-text-2); text-align: center; }
.empty-action { height: 38px; padding: 0 24px; background: var(--c-primary); color: var(--c-white); border-radius: 19px; font-size: 13px; font-weight: 700; letter-spacing: .02em; }

/* ══ Service Tab: Search ══════════════════════════════════════════════ */
#search-wrap  { flex-shrink: 0; background: var(--c-white); padding: 10px; border-bottom: 1px solid var(--c-border); display: flex; align-items: center; gap: 9px; }
#search-field { flex: 1; position: relative; }
#search-input { width: 100%; height: 34px; padding: 0 36px 0 14px; border: none; border-radius: 17px; background: var(--c-bg-2); font-family: inherit; font-size: 12px; font-weight: 500; color: #222; outline: none; }
#search-input::placeholder { color: var(--c-text-3); }
#search-clear { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; background: #bbb; border-radius: 50%; font-size: 9px; color: var(--c-white); display: none; align-items: center; justify-content: center; }
#search-btn   { flex-shrink: 0; height: 34px; padding: 0 16px; border-radius: 17px; font-size: 12px; font-weight: 700; letter-spacing: .02em; background: var(--c-primary); color: var(--c-white); white-space: nowrap; transition: background .15s; }
#search-btn:disabled { background: var(--c-bg-2); color: var(--c-text-3); cursor: not-allowed; }

/* ══ Service Tab: Selection Bar ═══════════════════════════════════════ */
#sel-bar    { flex-shrink: 0; height: 48px; background: var(--c-white); border-top: 1px solid var(--c-border); padding: 10px 0 10px 10px; display: none; align-items: center; gap: 6px; }
#sel-scroll { display: flex; gap: 6px; overflow-x: auto; align-items: center; width: 100%; padding-right: 10px; scrollbar-width: none; }
#sel-scroll::-webkit-scrollbar { display: none; }
.sel-reset  { display: inline-flex; align-items: center; flex-shrink: 0; height: 28px; padding: 0 10px; border-radius: var(--r-pill); font-size: 9px; font-weight: 500; border: 1.5px solid #ddd; background: #f5f5f5; color: #888; white-space: nowrap; }
.sel-tag    { display: inline-flex; align-items: center; gap: 5px; flex-shrink: 0; height: 28px; padding: 0 8px 0 3px; border-radius: var(--r-pill); font-size: 9px; font-weight: 500; background: var(--c-primary-bg); color: var(--c-primary-dk); border: 1.5px solid var(--c-primary); white-space: nowrap; cursor: pointer; }
.sel-tag.is-text-only { padding: 0 10px; }

/* ══ Date Tab: Date Boxes ═════════════════════════════════════════════ */
.date-boxes    { display: flex; flex-direction: column; gap: 6px; padding: 4px 10px 10px; }
.date-box      { display: flex; align-items: center; justify-content: space-between; height: 32px; padding: 0 10px; border-radius: var(--r-sm); background: var(--c-white); border: 1px solid #f0f0f0; cursor: pointer; transition: background .12s, border-color .12s; }
.date-box.is-on { background: var(--c-primary-bg); border-color: var(--c-primary-bg); }
.date-box-text  { font-size: 10px; font-weight: 500; color: var(--c-text-2); }
.date-box-text.is-all { font-weight: 700; color: #222; }
.date-box.is-on .date-box-text { color: var(--c-primary-dk); font-weight: 600; }
.date-box-check { width: 12px; height: 12px; border-radius: 50%; background: var(--c-primary); color: var(--c-white); font-size: 7px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.date-box-empty { width: 12px; height: 12px; flex-shrink: 0; }

/* ══ Type Tab: Filter Chips ═══════════════════════════════════════════ */
#type-chips { flex-shrink: 0; height: 40px; background: var(--c-white); border-bottom: 1px solid var(--c-border); display: flex; align-items: center; gap: 6px; padding: 0 10px; overflow-x: auto; scrollbar-width: none; }
#type-chips::-webkit-scrollbar { display: none; }
.type-chip { display: inline-flex; align-items: center; gap: 4px; height: 28px; padding: 0 8px 0 3px; border: 1.5px solid var(--c-border-2); border-radius: var(--r-pill); font-size: 9px; font-weight: 500; color: var(--c-text-2); background: var(--c-white); white-space: nowrap; user-select: none; flex-shrink: 0; transition: background .12s, border-color .12s, color .12s; }
.type-chip.is-text-only { padding: 0 10px; }
.type-chip[aria-pressed="true"] { background: var(--c-primary-bg); border-color: var(--c-primary); color: var(--c-primary-dk); }
.chip-x { font-size: 8px; color: #bbb; width: 13px; height: 13px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: background .1s, color .1s; }
.chip-x:hover { background: #e8e8e8; color: var(--c-text-2); }

/* ══ Type Tab: Image Grid ═════════════════════════════════════════════ */
#type-grid { flex: 1; min-height: 0; overflow-y: auto; padding: 8px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; align-content: start; }
#type-grid::-webkit-scrollbar { width: 3px; }
#type-grid::-webkit-scrollbar-thumb { background: #ccc; border-radius: 2px; }
.icard { display: flex; flex-direction: column; gap: 4px; cursor: pointer; }
.icard-thumb { position: relative; border-radius: 7px; overflow: hidden; aspect-ratio: 3/4; border: 2px solid transparent; background: #e4e4e4; transition: transform .12s, border-color .12s; }
.icard.is-on .icard-thumb { border-color: var(--c-primary); }
.icard.is-tapping .icard-thumb { transform: scale(.95); }
.icard-thumb::after { content: ''; position: absolute; inset: 0; background: rgba(114,100,255,.38); opacity: 0; transition: opacity .15s; z-index: 2; border-radius: inherit; }
.icard.is-on .icard-thumb::after { opacity: 1; }
.icard-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
.icard-logo   { position: absolute; bottom: 4px; left: 4px; width: 16px; height: 16px; border-radius: 50%; font-size: 7px; font-weight: 800; display: flex; align-items: center; justify-content: center; box-shadow: 0 1px 3px rgba(0,0,0,.35); z-index: 4; }
.icard-center { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 24px; height: 24px; border-radius: 50%; background: var(--c-white); color: var(--c-primary); font-size: 13px; font-weight: 800; display: none; align-items: center; justify-content: center; z-index: 3; box-shadow: 0 2px 6px rgba(0,0,0,.2); }
.icard.is-on .icard-center { display: flex; }
.icard-name   { font-size: 9px; font-weight: 500; color: var(--c-text-3); text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; line-height: 1.2; padding: 0 2px; }

/* ══ Done Screen ══════════════════════════════════════════════════════ */
.done-icon  { width: 56px; height: 56px; border-radius: 50%; background: var(--c-primary-bg); display: flex; align-items: center; justify-content: center; font-size: 26px; margin-bottom: 4px; }
.done-title { font-size: 15px; font-weight: 700; color: var(--c-text); text-align: center; }
.done-sub   { font-size: 11px; font-weight: 500; color: var(--c-text-3); text-align: center; line-height: 1.6; }
.done-badge { font-size: 10px; font-weight: 600; color: var(--c-primary); background: var(--c-primary-bg); border-radius: var(--r-pill); padding: 3px 10px; }
</style>
</head>
<body>
<div id="plugin" role="dialog" aria-label="디자인 리서치">

  <!-- 헤더 -->
  <div id="header">
    <div id="header-left">
      <div id="header-icon" aria-hidden="true"></div>
      <span id="header-title">디자인 리서치</span>
    </div>
    <button id="header-close" aria-label="닫기">✕</button>
  </div>

  <!-- 탭 바 -->
  <div id="tab-wrap">
    <div id="seg" role="tablist">
      <button class="seg-btn" role="tab" aria-selected="true"  data-tab="0">서비스</button>
      <button class="seg-btn" role="tab" aria-selected="false" data-tab="1" disabled>수집일</button>
      <button class="seg-btn" role="tab" aria-selected="false" data-tab="2" disabled>유형</button>
    </div>
  </div>

  <!-- 공통 고정 영역 -->
  <div id="common-fixed">
    <button id="common-all-chip" aria-pressed="false">전체 선택</button>
    <span id="common-n-count">선택한 조건 화면: <span>0건</span></span>
  </div>

  <!-- Tab 0: 서비스 -->
  <div id="screen-0" class="screen is-active">
    <div id="search-wrap">
      <div id="search-field">
        <input id="search-input" type="text" placeholder="서비스명을 정확히 입력하세요" autocomplete="off" aria-label="서비스 검색">
        <button id="search-clear" aria-label="검색어 지우기">✕</button>
      </div>
      <button id="search-btn" disabled>검색</button>
    </div>
    <div id="folder-list" class="list-wrap" role="list"></div>
    <div id="sel-bar" role="region" aria-label="선택된 서비스">
      <div id="sel-scroll"></div>
    </div>
    <div class="cta-wrap">
      <button id="cta-btn" class="cta-btn" disabled>서비스를 선택해 주세요</button>
    </div>
  </div>

  <!-- Tab 1: 수집일 -->
  <div id="screen-1" class="screen">
    <div id="date-list" class="list-wrap" role="list"></div>
    <div class="cta-wrap">
      <button id="date-cta-btn" class="cta-btn" disabled>수집일을 선택해 주세요</button>
    </div>
  </div>

  <!-- Tab 2: 유형 -->
  <div id="screen-2" class="screen">
    <div id="type-chips" role="group" aria-label="서비스 필터"></div>
    <div id="type-grid"  role="list"  aria-label="화면 목록"></div>
    <div class="cta-wrap">
      <button id="type-cta-btn" class="cta-btn" disabled>화면을 선택해 주세요</button>
    </div>
  </div>

  <!-- 완료 화면 (6-5 placeholder) -->
  <div id="screen-3" class="screen">
    <div class="done-icon">✓</div>
    <p class="done-title">Figma에 추가됐어요</p>
    <p class="done-sub">완료 화면은 6-5에서 구현 예정입니다</p>
    <span class="done-badge" id="done-badge"></span>
  </div>

</div>
<script>
'use strict';

/* ════════════════════════════════════════════
   DATA
════════════════════════════════════════════ */
const FOLDERS = [
  { id:'finance',   emoji:'💳', name:'finance',
    services:[{label:'토스',bg:'#0064FF',fg:'#fff',abbr:'T',count:21},{label:'카카오뱅크',bg:'#FFE000',fg:'#333',abbr:'K',count:14},{label:'네이버페이',bg:'#03C75A',fg:'#fff',abbr:'N',count:8},{label:'뱅크샐러드',bg:'#845EF7',fg:'#fff',abbr:'B',count:6}]},
  { id:'health',    emoji:'🏋️', name:'health-fitness',
    services:[{label:'강남언니',bg:'#FF4E8B',fg:'#fff',abbr:'강',count:21},{label:'바비톡',bg:'#FF8C00',fg:'#fff',abbr:'바',count:11},{label:'눔',bg:'#F04E23',fg:'#fff',abbr:'눔',count:5}]},
  { id:'commerce',  emoji:'🛍️', name:'commerce',
    services:[{label:'쿠팡',bg:'#FF4500',fg:'#fff',abbr:'C',count:7},{label:'배민',bg:'#2AC1BC',fg:'#fff',abbr:'B',count:13},{label:'올리브영',bg:'#008000',fg:'#fff',abbr:'O',count:5},{label:'무신사',bg:'#222',fg:'#fff',abbr:'M',count:11},{label:'당근마켓',bg:'#FF6F0F',fg:'#fff',abbr:'당',count:9}]},
  { id:'lifestyle', emoji:'🌿', name:'lifestyle',
    services:[{label:'야놀자',bg:'#FF0081',fg:'#fff',abbr:'야',count:6},{label:'여기어때',bg:'#E3007C',fg:'#fff',abbr:'여',count:4},{label:'오늘의집',bg:'#54C1C4',fg:'#fff',abbr:'오',count:7}]},
  { id:'social',    emoji:'💬', name:'social',
    services:[{label:'카카오톡',bg:'#FFE000',fg:'#333',abbr:'K',count:9},{label:'라인',bg:'#00B900',fg:'#fff',abbr:'L',count:5}]},
];

const SERVICE_DATES = {
  '토스':['2026.04','2026.02','2025.12'], '카카오뱅크':['2026.04','2026.01'],
  '네이버페이':['2026.04'], '뱅크샐러드':['2026.03','2025.11'],
  '강남언니':['2026.04'], '바비톡':['2026.04','2026.02'], '눔':['2026.04'],
  '쿠팡':['2026.04'], '배민':['2026.04','2026.03'], '올리브영':['2026.04'],
  '무신사':['2026.04','2026.01'], '당근마켓':['2026.04'],
  '야놀자':['2026.04','2025.12'], '여기어때':['2026.04'],
  '오늘의집':['2026.04','2026.02'], '카카오톡':['2026.04'], '라인':['2026.04'],
};

const UI_PATTERNS = ['필터','리스트','검색','추천/메인','로그인/회원가입','상세정보','리뷰','예약/결제','마이페이지','문의/FAQ','신청/결정','에러/빈화면'];

const ALL_SERVICES   = FOLDERS.flatMap(f => f.services);
const SERVICE_MAP    = new Map(ALL_SERVICES.map(s => [s.label, s]));
const TOTAL_SCREENS  = ALL_SERVICES.reduce((n, s) => n + s.count, 0);
const TOTAL_SERVICES = ALL_SERVICES.length;

const toFolderKey     = id  => `folder:${id}`;
const isFolderKey     = key => key.startsWith('folder:');
const folderIdFromKey = key => key.slice(7);
const $               = id  => document.getElementById(id);

/* ════════════════════════════════════════════
   STATE
════════════════════════════════════════════ */
const state = {
  /* Navigation */
  activeTab:    0,
  unlockedTabs: new Set([0]),
  /* Service tab */
  selected:     [],
  openFolders:  new Set(['finance']),
  searchResult: null,   /* null | Folder[] */
  /* Date tab */
  dateSelected:    new Map(),   /* Map<label, Set<'all'|dateStr>> */
  dateOpenFolders: new Set(),
  /* Type tab */
  typeImages:   [],
  typeSelected: new Set(),
  typeFilter:   null,
  typeIncluded: new Set(),
};

/* ════════════════════════════════════════════
   DOM
════════════════════════════════════════════ */
const dom = {
  segBtns:     document.querySelectorAll('.seg-btn'),
  commonFixed: $('common-fixed'),
  allChip:     $('common-all-chip'),
  nCount:      $('common-n-count'),
  searchInput: $('search-input'),
  searchBtn:   $('search-btn'),
  searchClear: $('search-clear'),
  folderList:  $('folder-list'),
  selBar:      $('sel-bar'),
  selScroll:   $('sel-scroll'),
  ctaBtn:      $('cta-btn'),
  dateList:    $('date-list'),
  dateCta:     $('date-cta-btn'),
  typeChips:   $('type-chips'),
  typeGrid:    $('type-grid'),
  typeCta:     $('type-cta-btn'),
};

/* ════════════════════════════════════════════
   NAVIGATION
════════════════════════════════════════════ */
function goTab(idx) {
  if (!state.unlockedTabs.has(idx)) return;
  state.activeTab = idx;

  document.querySelectorAll('.screen').forEach((s, i) =>
    s.classList.toggle('is-active', i === idx)
  );
  dom.commonFixed.style.display = 'flex';

  dom.segBtns.forEach(btn => {
    const t = +btn.dataset.tab, u = state.unlockedTabs.has(t);
    btn.setAttribute('aria-selected', String(t === idx));
    btn.disabled = !u;
    btn.classList.toggle('is-unlocked', u && t !== idx);
  });

  if (idx === 1) { _cleanDateState(); _renderDateFolders(); _syncDateCTA(); }

  _syncCommonFixed();
}

function unlockAndGoTab(idx) {
  state.unlockedTabs.add(idx);
  goTab(idx);
}

function showDone() {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('is-active'));
  $('screen-3').classList.add('is-active');
  dom.commonFixed.style.display = 'none';
}

/* ════════════════════════════════════════════
   COMMON FIXED AREA
════════════════════════════════════════════ */
function _isAllSelected() {
  switch (state.activeTab) {
    case 0: return _resolveSelectedLabels().size === TOTAL_SERVICES;
    case 1: {
      const svcs = _getDateTabServices();
      return svcs.length > 0 && svcs.every(s => state.dateSelected.get(s.label)?.has('all'));
    }
    case 2: {
      const vis = _getVisibleImages();
      return vis.length > 0 && vis.every(i => state.typeSelected.has(i.id));
    }
  }
  return false;
}

function _getConditionCount() {
  switch (state.activeTab) {
    case 0: return _countSelectedImages();
    case 1: return _countDateImages();
    case 2: return _getVisibleImages().length;
  }
  return 0;
}

function _syncCommonFixed() {
  dom.allChip.setAttribute('aria-pressed', String(_isAllSelected()));
  dom.nCount.innerHTML = `선택한 조건 화면: <span>${_getConditionCount()}건</span>`;
}

function _toggleAllByTab() {
  const all = _isAllSelected();
  switch (state.activeTab) {
    case 0:
      _applySelection(all ? [] : ['전체']);
      break;
    case 1: {
      const svcs = _getDateTabServices();
      svcs.forEach(s => {
        const d = new Set();
        if (!all) d.add('all');
        state.dateSelected.set(s.label, d);
      });
      _renderDateFolders(); _syncDateCTA(); _syncCommonFixed();
      break;
    }
    case 2: {
      const vis = _getVisibleImages();
      if (all) vis.forEach(i => state.typeSelected.delete(i.id));
      else     vis.forEach(i => state.typeSelected.add(i.id));
      _renderTypeGrid(); _renderTypeFilters(); _syncTypeCTA(); _syncCommonFixed();
      break;
    }
  }
}

/* ════════════════════════════════════════════
   SERVICE TAB — HELPERS
════════════════════════════════════════════ */
const _logoHTML = ({ bg, fg, abbr }) =>
  `<span class="chip-logo" style="background:${bg};color:${fg};">${abbr}</span>`;

function _resolveSelectedLabels() {
  if (state.selected.includes('전체'))
    return new Set(ALL_SERVICES.map(s => s.label));
  const labels = new Set();
  for (const val of state.selected) {
    if (isFolderKey(val))
      FOLDERS.find(f => f.id === folderIdFromKey(val))?.services.forEach(s => labels.add(s.label));
    else
      labels.add(val);
  }
  return labels;
}

function _countSelectedImages() {
  const labels = _resolveSelectedLabels();
  return labels.size
    ? ALL_SERVICES.filter(s => labels.has(s.label)).reduce((n, s) => n + s.count, 0)
    : 0;
}

/* ════════════════════════════════════════════
   SERVICE TAB — SELECTION
════════════════════════════════════════════ */
function _applySelection(next) {
  state.selected = next;
  _syncServiceCTA();
  _renderSelBar();
  _renderFolderList();
  _syncCommonFixed();
  _checkTabAccess();
}

function _toggleServiceSelection(val) {
  let next = [...state.selected];

  if (isFolderKey(val)) {
    const folder    = FOLDERS.find(f => f.id === folderIdFromKey(val));
    const svcLabels = folder.services.map(s => s.label);
    if (next.includes(val)) {
      next = next.filter(x => x !== val);
    } else {
      next = next.filter(x => !svcLabels.includes(x) && x !== '전체');
      next.unshift(val);
    }
  } else {
    const folder    = FOLDERS.find(f => f.services.some(s => s.label === val));
    const folderKey = folder ? toFolderKey(folder.id) : null;
    next = next.filter(x => x !== '전체' && x !== folderKey);
    const idx = next.indexOf(val);
    idx > -1 ? next.splice(idx, 1) : next.unshift(val);
  }
  _applySelection(next);
}

function _checkTabAccess() {
  if (_resolveSelectedLabels().size > 0) return;
  state.unlockedTabs.delete(1);
  state.unlockedTabs.delete(2);
  if (state.activeTab > 0) {
    goTab(0);
  } else {
    dom.segBtns.forEach(btn => {
      const t = +btn.dataset.tab, u = state.unlockedTabs.has(t);
      btn.disabled = !u;
      btn.classList.toggle('is-unlocked', u && t !== state.activeTab);
    });
  }
}

/* ════════════════════════════════════════════
   SERVICE TAB — SEARCH
════════════════════════════════════════════ */
function _clearSearch() {
  state.searchResult    = null;
  dom.searchInput.value = '';
  _syncSearchUI();
  _renderFolderList();
}

function _runSearch() {
  const q = dom.searchInput.value.trim();
  if (!q) return;

  state.searchResult     = null;
  dom.searchBtn.disabled = true;
  _renderSkeleton();

  /* Drive 연동 시 setTimeout → API 호출로 교체 */
  setTimeout(() => {
    const matched = FOLDERS
      .map(f => ({ ...f, services: f.services.filter(s => s.label.includes(q)) }))
      .filter(f => f.services.length > 0);
    state.searchResult = matched.length > 0 ? matched : [];
    _syncSearchUI();
    _renderFolderList();
  }, 1500);
}

function _syncSearchUI() {
  const hasVal = dom.searchInput.value.trim().length > 0;
  dom.searchBtn.disabled        = !hasVal;
  dom.searchClear.style.display = hasVal ? 'flex' : 'none';
}

function _syncServiceCTA() {
  const n = _resolveSelectedLabels().size;
  dom.ctaBtn.disabled    = !n;
  dom.ctaBtn.textContent = n ? '다음' : '서비스를 선택해 주세요';
}

/* ════════════════════════════════════════════
   SERVICE TAB — RENDER
════════════════════════════════════════════ */
function _renderSkeleton() {
  const chipSkel = n => Array.from({ length: n }, (_, i) =>
    `<div class="sk" style="width:${44+(i%3)*14}px;height:28px;border-radius:100px;"></div>`
  ).join('');
  dom.folderList.innerHTML = [3, 5, 4].map(n => `
    <div class="skeleton-card">
      <div class="skeleton-row">
        <div class="sk sk-circle" style="width:20px;height:20px;"></div>
        <div class="sk" style="width:${70+n*8}px;height:14px;"></div>
      </div>
      <div class="skeleton-chips">${chipSkel(n)}</div>
    </div>`).join('');
}

function _renderFolderList() {
  _stopEmojiCycle();

  if (state.searchResult !== null && !state.searchResult.length) {
    const q = dom.searchInput.value;
    dom.folderList.innerHTML = `
      <div class="empty-state">
        <div class="empty-emoji is-shaking" id="empty-emoji">🔍</div>
        <p class="empty-title">'${q}'은(는) 등록되지 않았어요</p>
        <button class="empty-action" id="empty-browse">전체 목록 보기</button>
      </div>`;
    _startEmojiCycle();
    return;
  }

  const folders      = state.searchResult ?? FOLDERS;
  const inSearchMode = state.searchResult !== null;

  dom.folderList.innerHTML = folders.map(folder => {
    const isOpen     = state.openFolders.has(folder.id) || inSearchMode;
    const folderKey  = toFolderKey(folder.id);
    const isFolderOn = state.selected.includes(folderKey);
    const selCount   = isFolderOn
      ? folder.services.length
      : folder.services.filter(s => state.selected.includes(s.label)).length;

    const chipsHTML = isOpen ? `
      <div class="folder-chips">
        <button class="chip is-text-only" aria-pressed="${isFolderOn}" data-val="${folderKey}">전체</button>
        ${folder.services.map(s => {
          const isOn = isFolderOn || state.selected.includes(s.label);
          return `<button class="chip" aria-pressed="${isOn}" data-val="${s.label}">${_logoHTML(s)}${s.label}</button>`;
        }).join('')}
      </div>` : '';

    return `
      <div class="folder" role="listitem">
        <div class="folder-header" data-folder-id="${folder.id}">
          <div class="folder-header-left">
            <span class="folder-arrow ${isOpen ? 'is-open' : ''}" aria-hidden="true">▶</span>
            <span class="folder-emoji" aria-hidden="true">${folder.emoji}</span>
            <span class="folder-name">${folder.name}</span>
            <span class="folder-count">(${folder.services.length})</span>
          </div>
          ${selCount > 0 ? `<span class="folder-badge">${selCount}</span>` : ''}
        </div>
        ${chipsHTML}
      </div>`;
  }).join('')
  + (inSearchMode ? `
    <div style="display:flex;justify-content:center;padding:20px 0 4px;">
      <button class="empty-action" id="show-all-btn">전체 목록 보기</button>
    </div>` : '');
}

function _renderSelBar() {
  dom.selBar.querySelector('.sel-reset')?.remove();
  dom.selScroll.innerHTML = '';

  if (!state.selected.length) { dom.selBar.style.display = 'none'; return; }

  dom.selScroll.innerHTML = state.selected.map(val => {
    if (val === '전체')
      return `<button class="sel-tag is-text-only" data-val="전체">전체 <span aria-hidden="true">✕</span></button>`;
    if (isFolderKey(val)) {
      const f = FOLDERS.find(f => f.id === folderIdFromKey(val));
      return `<button class="sel-tag is-text-only" data-val="${val}">${f?.emoji ?? ''} 전체 <span aria-hidden="true">✕</span></button>`;
    }
    const svc = SERVICE_MAP.get(val);
    return `<button class="sel-tag" data-val="${val}">${svc ? _logoHTML(svc) : ''}${val} <span aria-hidden="true">✕</span></button>`;
  }).join('');

  const resetBtn = document.createElement('button');
  resetBtn.className   = 'sel-reset';
  resetBtn.textContent = '초기화';
  dom.selBar.insertBefore(resetBtn, dom.selScroll);
  dom.selBar.style.display = 'flex';
}

/* ════════════════════════════════════════════
   EMOJI CYCLE
════════════════════════════════════════════ */
const EMPTY_EMOJIS = ['🔍', '🤔', '😢'];
let _emojiTimer = null, _emojiIdx = 0;

function _startEmojiCycle() {
  _stopEmojiCycle();
  _emojiIdx   = 0;
  _emojiTimer = setInterval(() => {
    const el = $('empty-emoji');
    if (!el) { _stopEmojiCycle(); return; }
    el.style.opacity = '0';
    setTimeout(() => {
      const el2 = $('empty-emoji');
      if (!el2) return;
      _emojiIdx         = (_emojiIdx + 1) % EMPTY_EMOJIS.length;
      el2.textContent   = EMPTY_EMOJIS[_emojiIdx];
      el2.style.opacity = '1';
      el2.classList.remove('is-shaking');
      void el2.offsetWidth;
      el2.classList.add('is-shaking');
    }, 300);
  }, 2000);
}

function _stopEmojiCycle() {
  clearInterval(_emojiTimer);
  _emojiTimer = null;
}

/* ════════════════════════════════════════════
   DATE TAB — HELPERS
════════════════════════════════════════════ */
function _getDateTabServices() {
  const labels = _resolveSelectedLabels();
  return ALL_SERVICES.filter(s => labels.has(s.label));
}

function _countDateImages() {
  return _getDateTabServices().reduce((sum, svc) => {
    const sel = state.dateSelected.get(svc.label);
    if (!sel?.size) return sum;
    if (sel.has('all')) return sum + svc.count;
    const total = (SERVICE_DATES[svc.label] || []).length;
    return sum + Math.round(svc.count * (total ? sel.size / total : 0));
  }, 0);
}

function _cleanDateState() {
  const labels = _resolveSelectedLabels();
  for (const key of state.dateSelected.keys())
    if (!labels.has(key)) state.dateSelected.delete(key);
  for (const key of state.dateOpenFolders)
    if (!labels.has(key)) state.dateOpenFolders.delete(key);

  const svcs  = _getDateTabServices();
  const hasOpen = [...state.dateOpenFolders].some(f => labels.has(f));
  if (svcs.length > 0 && !hasOpen) state.dateOpenFolders.add(svcs[0].label);
}

/* ════════════════════════════════════════════
   DATE TAB — SELECTION
════════════════════════════════════════════ */
function _enterDateTab() {
  const svcs = _getDateTabServices();
  state.dateSelected    = new Map();
  state.dateOpenFolders = new Set(svcs.length ? [svcs[0].label] : []);
  _renderDateFolders(); _syncDateCTA();
  unlockAndGoTab(1);
}

function _toggleDate(svcLabel, date) {
  if (!state.dateSelected.has(svcLabel))
    state.dateSelected.set(svcLabel, new Set());
  const sel = state.dateSelected.get(svcLabel);

  if (date === '전체') {
    if (sel.has('all')) sel.delete('all');
    else { sel.clear(); sel.add('all'); }
  } else {
    sel.delete('all');
    sel.has(date) ? sel.delete(date) : sel.add(date);
  }
  _renderDateFolders(); _syncDateCTA(); _syncCommonFixed();
}

function _syncDateCTA() {
  const n = _countDateImages();
  dom.dateCta.disabled    = !n;
  dom.dateCta.textContent = n ? '다음' : '수집일을 선택해 주세요';
}

/* ════════════════════════════════════════════
   DATE TAB — RENDER
════════════════════════════════════════════ */
function _renderDateFolders() {
  const svcs = _getDateTabServices();

  if (!svcs.length) {
    dom.dateList.innerHTML = '<div class="empty-state"><p class="empty-title">선택된 서비스가 없어요</p></div>';
    return;
  }

  dom.dateList.innerHTML = svcs.map(svc => {
    const isOpen = state.dateOpenFolders.has(svc.label);
    const sel    = state.dateSelected.get(svc.label) || new Set();
    const badge  = sel.has('all') ? 1 : sel.size;
    const dates  = SERVICE_DATES[svc.label] || [];

    const boxesHTML = isOpen ? `
      <div class="date-boxes">
        ${['전체', ...dates].map(d => {
          const isOn  = d === '전체' ? sel.has('all') : !sel.has('all') && sel.has(d);
          const isAll = d === '전체';
          return `
            <div class="date-box${isOn ? ' is-on' : ''}" data-date="${d}" data-svc="${svc.label}">
              <span class="date-box-text${isAll && !isOn ? ' is-all' : ''}">${d}</span>
              ${isOn
                ? `<span class="date-box-check" aria-hidden="true">✓</span>`
                : `<span class="date-box-empty"></span>`}
            </div>`;
        }).join('')}
      </div>` : '';

    return `
      <div class="folder" role="listitem">
        <div class="folder-header" data-date-svc="${svc.label}">
          <div class="folder-header-left">
            <span class="folder-arrow ${isOpen ? 'is-open' : ''}" aria-hidden="true">▶</span>
            <span class="chip-logo" style="background:${svc.bg};color:${svc.fg};width:20px;height:20px;font-size:9px;">${svc.abbr}</span>
            <span class="folder-name">${svc.label}</span>
            <span class="folder-count">(${dates.length})</span>
          </div>
          ${badge > 0 ? `<span class="folder-badge">${badge}</span>` : ''}
        </div>
        ${boxesHTML}
      </div>`;
  }).join('');
}

/* ════════════════════════════════════════════
   TYPE TAB — SVG THUMBNAILS
════════════════════════════════════════════ */
function _makeSvgThumb(bg, fg, idx) {
  const W = 81, H = 108, v = (m, r) => (idx * m) % r, p = idx % 6;
  let inner = '';
  switch (p) {
    case 0: inner = `
      <rect x="8" y="8" width="${30+v(17,22)}" height="7" rx="3.5" fill="${fg}" opacity=".42"/>
      <rect x="8" y="20" width="${W-16}" height="1" fill="${fg}" opacity=".1"/>
      ${[28,43,58,73].map((y,i) => `
        <circle cx="16" cy="${y+4}" r="5.5" fill="${fg}" opacity=".25"/>
        <rect x="28" y="${y}" width="${22+(idx+i*9)%20}" height="5" rx="2.5" fill="${fg}" opacity=".38"/>
        <rect x="28" y="${y+8}" width="${14+(idx+i*7)%14}" height="4" rx="2" fill="${fg}" opacity=".2"/>
      `).join('')}`; break;
    case 1: { const hw=(W-22)>>1; inner=`
      <rect x="8" y="8" width="${28+v(19,18)}" height="7" rx="3.5" fill="${fg}" opacity=".4"/>
      <rect x="8" y="20" width="${W-16}" height="36" rx="6" fill="${fg}" opacity=".2"/>
      <rect x="8" y="62" width="${hw}" height="36" rx="5" fill="${fg}" opacity=".18"/>
      <rect x="${hw+14}" y="62" width="${hw}" height="36" rx="5" fill="${fg}" opacity=".18"/>`; break; }
    case 2: { const h=38+v(11,12), y0=h+6; inner=`
      <rect x="0" y="0" width="${W}" height="${h}" fill="${fg}" opacity=".22"/>
      <rect x="8" y="${y0}" width="${32+v(19,16)}" height="7" rx="3.5" fill="${fg}" opacity=".4"/>
      <rect x="8" y="${y0+10}" width="${24+v(13,14)}" height="5" rx="2.5" fill="${fg}" opacity=".25"/>
      <rect x="8" y="${y0+19}" width="${W-16}" height="10" rx="5" fill="${fg}" opacity=".16"/>
      <rect x="8" y="${y0+33}" width="${W-16}" height="12" rx="6" fill="${fg}" opacity=".3"/>`; break; }
    case 3: inner=`
      <rect x="8" y="8" width="${W-16}" height="10" rx="5" fill="${fg}" opacity=".18"/>
      ${[36,50,64,78].map((y,i) => `
        <rect x="8" y="${y}" width="${W-16}" height="10" rx="5" fill="${fg}" opacity=".14"/>
        <rect x="16" y="${y+3}" width="${18+(idx+i*9)%22}" height="4" rx="2" fill="${fg}" opacity=".3"/>
      `).join('')}`; break;
    case 4: { const cx=W>>1; inner=`
      <circle cx="${cx}" cy="22" r="${10+v(7,6)}" fill="${fg}" opacity=".28"/>
      <rect x="${cx-15}" y="40" width="30" height="6" rx="3" fill="${fg}" opacity=".35"/>
      ${[68,80,92].map((y,i) => `
        <rect x="8" y="${y}" width="${W-16}" height="9" rx="4.5" fill="${fg}" opacity=".13"/>
        <rect x="14" y="${y+2}" width="${16+(idx+i*9)%16}" height="4" rx="2" fill="${fg}" opacity=".3"/>
      `).join('')}`; break; }
    case 5: inner=`
      <rect x="8" y="8" width="${26+v(19,16)}" height="7" rx="3.5" fill="${fg}" opacity=".4"/>
      ${[22,42,62].map((y,i) => `
        <rect x="8" y="${y}" width="${12+(i*7)%14}" height="4" rx="2" fill="${fg}" opacity=".28"/>
        <rect x="8" y="${y+6}" width="${W-16}" height="11" rx="5.5" fill="${fg}" opacity=".14"/>
      `).join('')}
      <rect x="8" y="88" width="${W-16}" height="13" rx="6.5" fill="${fg}" opacity=".32"/>`; break;
  }
  const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${W}" height="${H}" viewBox="0 0 ${W} ${H}">
    <rect width="${W}" height="${H}" fill="${bg}"/>${inner}</svg>`;
  return 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(svg);
}

/* ════════════════════════════════════════════
   TYPE TAB — IMAGE GENERATION
════════════════════════════════════════════ */
function _generateImages(labels) {
  const imgs = []; let uid = 0;
  for (const folder of FOLDERS)
    for (const svc of folder.services) {
      if (!labels.has(svc.label)) continue;
      for (let i = 0; i < svc.count; i++, uid++)
        imgs.push({ id:`img-${uid}`, svcLabel:svc.label, svc, pattern:UI_PATTERNS[uid%UI_PATTERNS.length], thumbUrl:_makeSvgThumb(svc.bg, svc.fg, uid) });
    }
  return imgs;
}

function _getVisibleImages() {
  let imgs = state.typeImages.filter(i => state.typeIncluded.has(i.svcLabel));
  if (state.typeFilter) imgs = imgs.filter(i => i.svcLabel === state.typeFilter);
  return imgs;
}

/* ════════════════════════════════════════════
   TYPE TAB — ENTRY & CTA
════════════════════════════════════════════ */
function _enterTypeTab() {
  const labels = _resolveSelectedLabels();
  state.typeImages   = _generateImages(labels);
  state.typeSelected = new Set();
  state.typeFilter   = null;
  state.typeIncluded = new Set(labels);
  _renderTypeFilters(); _renderTypeGrid(); _syncTypeCTA();
  unlockAndGoTab(2);
}

function _syncTypeCTA() {
  const n = state.typeSelected.size;
  dom.typeCta.disabled    = !n;
  dom.typeCta.textContent = n ? '불러오기' : '화면을 선택해 주세요';
}

function _animateCountdown(from, to) {
  let cur = from;
  dom.typeCta.classList.add('is-counting');
  const iv = setInterval(() => {
    cur--;
    if (cur <= to) {
      clearInterval(iv);
      dom.typeCta.disabled    = to === 0;
      dom.typeCta.textContent = to === 0 ? '화면을 선택해 주세요' : '불러오기';
      setTimeout(() => dom.typeCta.classList.remove('is-counting'), 250);
      return;
    }
    dom.typeCta.textContent = '불러오기';
  }, 70);
}

/* ════════════════════════════════════════════
   TYPE TAB — RENDER
════════════════════════════════════════════ */
function _renderTypeFilters() {
  const counts       = new Map();
  const totalVisible = state.typeImages.filter(i => state.typeIncluded.has(i.svcLabel)).length;
  for (const img of state.typeImages)
    if (state.typeIncluded.has(img.svcLabel))
      counts.set(img.svcLabel, (counts.get(img.svcLabel) ?? 0) + 1);

  const vis    = _getVisibleImages();
  const allSel = vis.length > 0 && vis.every(i => state.typeSelected.has(i.id));
  const allOn  = state.typeFilter === null && allSel;

  let html = `<button class="type-chip is-text-only" aria-pressed="${allOn}" data-action="all">
    전체 <span style="font-weight:700;color:${state.typeFilter===null?'#3D2FCC':'#aaa'}">${totalVisible}</span>
  </button>`;

  counts.forEach((cnt, label) => {
    const svc = SERVICE_MAP.get(label), isActive = state.typeFilter === label;
    html += `<button class="type-chip" aria-pressed="${isActive}" data-action="filter" data-label="${label}">
      <span class="chip-logo" style="background:${svc.bg};color:${svc.fg};width:16px;height:16px;font-size:7px;">${svc.abbr}</span>
      ${label} <span style="font-weight:700;color:${isActive?'#3D2FCC':'#aaa'}">${cnt}</span>
      <span class="chip-x" data-action="remove" data-label="${label}" aria-label="${label} 제거">✕</span>
    </button>`;
  });
  dom.typeChips.innerHTML = html;
}

function _renderTypeGrid() {
  dom.typeGrid.innerHTML = _getVisibleImages().map(img => {
    const isOn = state.typeSelected.has(img.id);
    return `
      <div class="icard${isOn ? ' is-on' : ''}" role="listitem" data-id="${img.id}" aria-pressed="${isOn}">
        <div class="icard-thumb">
          <img src="${img.thumbUrl}" alt="${img.pattern}" loading="lazy">
          <span class="icard-logo" style="background:${img.svc.bg};color:${img.svc.fg};">${img.svc.abbr}</span>
          <span class="icard-center" aria-hidden="true">✓</span>
        </div>
        <p class="icard-name">${img.pattern}</p>
      </div>`;
  }).join('');
}

/* ════════════════════════════════════════════
   EVENT BINDINGS — 이벤트 위임
════════════════════════════════════════════ */

/* 탭 바 */
dom.segBtns.forEach(btn =>
  btn.addEventListener('click', () => goTab(+btn.dataset.tab))
);

/* 공통: 전체 선택 */
dom.allChip.addEventListener('click', _toggleAllByTab);

/* 서비스: 검색 */
dom.searchInput.addEventListener('input', _syncSearchUI);
dom.searchInput.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !dom.searchBtn.disabled) _runSearch();
});
dom.searchBtn.addEventListener('click', _runSearch);
dom.searchClear.addEventListener('click', _clearSearch);

/* 서비스: 폴더 리스트 (위임) */
dom.folderList.addEventListener('click', e => {
  const actionBtn = e.target.closest('#show-all-btn, #empty-browse');
  const chip      = e.target.closest('.chip[data-val]');
  const header    = e.target.closest('.folder-header[data-folder-id]');

  if (actionBtn) {
    _clearSearch();
  } else if (chip) {
    e.stopPropagation();
    _toggleServiceSelection(chip.dataset.val);
  } else if (header) {
    const id = header.dataset.folderId;
    state.openFolders.has(id) ? state.openFolders.delete(id) : state.openFolders.add(id);
    _renderFolderList();
  }
});

/* 서비스: 선택 바 (위임) */
dom.selScroll.addEventListener('click', e => {
  const tag = e.target.closest('.sel-tag[data-val]');
  if (tag) _applySelection(state.selected.filter(x => x !== tag.dataset.val));
});
dom.selBar.addEventListener('click', e => {
  if (e.target.closest('.sel-reset')) _applySelection([]);
});

/* 서비스 CTA */
dom.ctaBtn.addEventListener('click', _enterDateTab);

/* 수집일: 날짜 리스트 (위임) */
dom.dateList.addEventListener('click', e => {
  const header = e.target.closest('.folder-header[data-date-svc]');
  const box    = e.target.closest('.date-box[data-date]');

  if (header) {
    const sv = header.dataset.dateSvc;
    state.dateOpenFolders.has(sv) ? state.dateOpenFolders.delete(sv) : state.dateOpenFolders.add(sv);
    _renderDateFolders();
  } else if (box) {
    _toggleDate(box.dataset.svc, box.dataset.date);
  }
});

/* 수집일 CTA */
dom.dateCta.addEventListener('click', _enterTypeTab);

/* 유형: 필터 칩 (위임) */
dom.typeChips.addEventListener('click', e => {
  const el = e.target.closest('[data-action]');
  if (!el) return;
  e.stopPropagation();
  const { action, label } = el.dataset;

  if (action === 'all') {
    if (state.typeFilter !== null) {
      state.typeFilter = null;
    } else {
      const vis = _getVisibleImages(), allSel = vis.every(i => state.typeSelected.has(i.id));
      if (allSel) vis.forEach(i => state.typeSelected.delete(i.id));
      else        vis.forEach(i => state.typeSelected.add(i.id));
    }
    _renderTypeFilters(); _renderTypeGrid(); _syncTypeCTA(); _syncCommonFixed();

  } else if (action === 'filter') {
    state.typeFilter = state.typeFilter === label ? null : label;
    _renderTypeFilters(); _renderTypeGrid(); _syncTypeCTA(); _syncCommonFixed();

  } else if (action === 'remove') {
    const removed = state.typeImages.filter(i => i.svcLabel === label && state.typeSelected.has(i.id));
    state.typeIncluded.delete(label);
    removed.forEach(i => state.typeSelected.delete(i.id));
    if (state.typeFilter === label) state.typeFilter = null;
    const oldSel = state.typeSelected.size + removed.length;
    _renderTypeFilters(); _renderTypeGrid();
    removed.length > 0 ? _animateCountdown(oldSel, state.typeSelected.size) : _syncTypeCTA();
    _syncCommonFixed();
  }
});

/* 유형: 이미지 그리드 (위임) */
dom.typeGrid.addEventListener('click', e => {
  const card = e.target.closest('.icard[data-id]');
  if (!card) return;
  card.classList.add('is-tapping');
  setTimeout(() => card.classList.remove('is-tapping'), 120);
  const id = card.dataset.id;
  state.typeSelected.has(id) ? state.typeSelected.delete(id) : state.typeSelected.add(id);
  _renderTypeGrid(); _renderTypeFilters(); _syncTypeCTA(); _syncCommonFixed();
});

/* 유형 CTA */
dom.typeCta.addEventListener('click', () => {
  $('done-badge').textContent = `${state.typeSelected.size}개 화면 선택됨`;
  showDone();
});

/* ════════════════════════════════════════════
   INIT
════════════════════════════════════════════ */
(function init() {
  _syncServiceCTA();
  _syncCommonFixed();
  _renderFolderList();
  goTab(0);
}());
</script>
</body>
</html>